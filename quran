# Global variables for indexing
_quran_index = None

def get_quran_index():
    """Load and index translation verses."""
    global _quran_index
    if _quran_index is not None:
        return _quran_index

    path = get_json_path()
    try:
        with open(path, 'r', encoding='utf-8') as f:
            data = json.load(f)
    except Exception as e:
        print(f"\033[1;31mError reading translation database: {e}\033[0m")
        sys.exit(1)

    verses = data.get('quran', [])
    db = {}
    for v in verses:
        ch = v['chapter']
        ver = v['verse']
        txt = v['text']
        if ch not in db:
            db[ch] = {}
        db[ch][ver] = txt

    # Shift Fatihah (Chapter 1) so Alhamdulillah is counted as Verse 1
    if 1 in db:
        fatihah_shifted = {
            1: "[All] praise is [due] to Allah, Lord of the worlds -",
            2: "The Entirely Merciful, the Especially Merciful,",
            3: "Sovereign of the Day of Recompense.",
            4: "It is You we worship and You we ask for help.",
            5: "Guide us to the straight path -",
            6: "The path of those upon whom You have bestowed favor,",
            7: "not of those who have evoked [Your] anger or of those who are astray."
        }
        db[1] = fatihah_shifted

    _quran_index = db
    return db

def print_verse(chapter_num, verse_num, text, surah_name):
    """Nicely print wrapped and colorized verse."""
    term_width = shutil.get_terminal_size((80, 20)).columns
    wrap_width = max(40, min(term_width - 8, 100))
    
    # Verse location label
    prefix = f"\033[1;33m[{chapter_num}:{verse_num}]\033[0m "
    
    # Indentation for lines after the first
    indent = " " * len(f"[{chapter_num}:{verse_num}] ")
    
    wrapped = textwrap.fill(text, width=wrap_width, initial_indent="", subsequent_indent=indent)
    print(f"{prefix}{wrapped}\n")

def clean_html(html_text):
    """Strip HTML tags, unescape entities, and clean up spacing for the terminal."""
    text = html_text
    # Convert block level tags to newlines
    text = re.sub(r'</?(p|h1|h2|h3|h4|div|br|li|ul|ol)[^>]*>', '\n', text)
    # Remove all other tags
    text = re.sub(r'<[^>]+>', '', text)
    # Unescape HTML entities
    import html
    text = html.unescape(text)
    # Collapse multiple newlines
    text = re.sub(r'\n\s*\n+', '\n\n', text)
    return text.strip()

def get_api_verse(chapter, verse):
    """Map local verse to Kufan api.quran.com verse numbering for Chapter 1."""
    if chapter == 1:
        if verse in (6, 7):
            return 7
        return verse + 1
    return verse

def get_tafsir_text(chapter, verse, tafsir_id=169):
    """Retrieve and clean Tafsir text for a specific Tafsir ID, using local cache or API."""
    home = os.path.expanduser("~")
    cache_dir = os.path.join(home, ".local", "share", "quran", "tafsir_cache")
    os.makedirs(cache_dir, exist_ok=True)
    cache_file = os.path.join(cache_dir, f"{chapter}_{verse}_{tafsir_id}.json")
    
    if os.path.exists(cache_file):
        try:
            with open(cache_file, 'r', encoding='utf-8') as f:
                data = json.load(f)
                return clean_html(data.get('tafsir', {}).get('text', ''))
        except Exception:
            pass
            
    # Fetch from API using mapped verse
    api_verse = get_api_verse(chapter, verse)
    url = f"https://api.quran.com/api/v4/tafsirs/{tafsir_id}/by_ayah/{chapter}:{api_verse}"
    try:
        import urllib.request
        req = urllib.request.Request(
            url, 
            headers={'User-Agent': 'Mozilla/5.0'}
        )
        with urllib.request.urlopen(req, timeout=5) as response:
            data = json.load(response)
            with open(cache_file, 'w', encoding='utf-8') as f:
                json.dump(data, f, ensure_ascii=False)
            return clean_html(data.get('tafsir', {}).get('text', ''))
    except Exception as e:
        return f"\033[1;31m[Error fetching Tafsir: {e}. Please check your internet connection.]\033[0m"

def display_verses(surah, verse_start=None, verse_end=None, show_tafsir=False):
    """Query database and print results with custom pager."""
    ch_id = surah["id"]
    db = get_quran_index()
    
    if ch_id not in db:
        print(f"\033[1;31mError: Translation data for Chapter {ch_id} not found.\033[0m")
        return
        
    ch_data = db[ch_id]
    
    # Determine bounds
    if verse_start is None:
        v_start = 1
        v_end = surah["verses"]
        title = f"Surah {surah['name']} ({surah['english']})"
    else:
        v_start = verse_start
        v_end = verse_end
        if v_start == v_end:
            title = f"Surah {surah['name']} ({surah['english']}) — Verse {v_start}"
        else:
            title = f"Surah {surah['name']} ({surah['english']}) — Verses {v_start} to {v_end}"

    # Print beautiful header
    print(f"\033[1;36m{'=' * min(60, shutil.get_terminal_size().columns)}\033[0m")
    print(f"\033[1;32m{title}\033[0m")
    print(f"\033[1;30mChapter {surah['id']} | Total Verses: {surah['verses']}\033[0m")
    print(f"\033[1;36m{'=' * min(60, shutil.get_terminal_size().columns)}\033[0m\n")

    # Center the Bismillah if starting from verse 1 (except Chapter 9 which does not have it)
    if v_start == 1 and ch_id != 9:
        bismillah = "In the name of Allah, the Entirely Merciful, the Especially Merciful"
        term_width = shutil.get_terminal_size((80, 20)).columns
        print(f"\033[1;36m{bismillah.center(term_width)}\033[0m\n")

    is_tty = sys.stdout.isatty()
    term_height = shutil.get_terminal_size((80, 24)).lines
    page_size = max(5, term_height - 6)
    
    accumulated_lines = 0
    for v_num in range(v_start, v_end + 1):
        if v_num not in ch_data:
            continue
            
        text = ch_data[v_num]
        
        # Calculate screen lines for pagination
        term_width = shutil.get_terminal_size((80, 20)).columns
        wrap_width = max(40, min(term_width - 8, 100))
        verse_lines = len(textwrap.wrap(text, width=wrap_width)) + 1 # +1 for empty line spacer
        
        # Approximate lines for Tafsir if displayed (3 sources)
        tafsir_lines = 0
        if show_tafsir:
            tafsir_lines = 30
            
        if is_tty and accumulated_lines > 0 and accumulated_lines + verse_lines + tafsir_lines > page_size:
            try:
                prompt = "\033[1;30m--- Press Enter for more, Q to quit ---\033[0m"
                ans = input(prompt).strip().lower()
                if ans == 'q':
                    print()
                    return
                # Clear the prompt line to keep output neat
                sys.stdout.write("\033[F\033[K")
            except (KeyboardInterrupt, EOFError):
                print()
                return
            accumulated_lines = 0
            
        print_verse(ch_id, v_num, text, surah["name"])
        accumulated_lines += verse_lines
        
        if show_tafsir:
            tafsir_sources = [
                (817, "Tazkirul Quran", "\033[1;33m"),
                (169, "Tafsir Ibn Kathir", "\033[1;35m"),
                (168, "Ma'arif al-Qur'an", "\033[1;34m"),
            ]
            for t_id, t_name, t_color in tafsir_sources:
                print(f"   {t_color}--- {t_name} ---\033[0m")
                tafsir_text = get_tafsir_text(ch_id, v_num, t_id)
                
                paragraphs = tafsir_text.split('\n\n')
                wrapped_paragraphs = []
                for p in paragraphs:
                    if p.strip():
                        wrapped_p = textwrap.fill(p.strip(), width=wrap_width, initial_indent="   ", subsequent_indent="   ")
                        wrapped_paragraphs.append(wrapped_p)
                
                full_tafsir_formatted = "\n\n".join(wrapped_paragraphs)
                print(f"{full_tafsir_formatted}\n")
                
                # Recalculate exact lines used by Tafsir
                actual_tafsir_lines = sum(len(textwrap.wrap(p.strip(), width=wrap_width)) for p in paragraphs if p.strip()) + len(paragraphs)*2 + 2
                accumulated_lines += actual_tafsir_lines
                
            print(f"\033[1;36m   {'=' * min(40, term_width - 8)}\033[0m\n")
            accumulated_lines += 2

