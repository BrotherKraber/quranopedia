def main():
    if len(sys.argv) == 1:
        print_help()
        print_surah_list()
        return

    # Check for Tafsir flags anywhere in arguments
    show_tafsir = False
    filtered_args = []
    for arg in sys.argv[1:]:
        if arg.lower() in ('-t', '--tafsir'):
            show_tafsir = True
        else:
            filtered_args.append(arg)

    if len(filtered_args) == 0:
        print_help()
        return

    # Check for help flags
    first_arg = filtered_args[0].lower().strip()
    if first_arg in ('-h', '--help', 'help'):
        print_help()
        return
        
    if first_arg == 'list':
        print_surah_list()
        return

    # Process search query
    query_str = " ".join(filtered_args)
    chapter_query, verse_start, verse_end = parse_query(query_str)
    
    # Lookup Surah
    result = find_surah(chapter_query)
    
    if result is None:
        print(f"\033[1;31mError: Chapter '{chapter_query}' not found.\033[0m")
        print("Type \033[1;32mquran list\033[0m to see all available chapters.")
        sys.exit(1)
        
    elif isinstance(result, list):
        # Multiple matches / suggestions
        print(f"\033[1;33mMultiple chapters matched your query '{chapter_query}':\033[0m")
        for s in result:
            print(f"  \033[1;32m{s['id']:3d}. {s['name']}\033[0m ({s['english']})")
        print("\nPlease be more specific, or query by chapter number.")
        sys.exit(1)
        
    else:
        # Unique Surah found
        surah = result
        
        # Validate verses if specified
        if verse_start is not None:
            max_verses = surah["verses"]
            
            if verse_start < 1 or verse_start > max_verses:
                print(f"\033[1;31mError: Surah {surah['name']} only has {max_verses} verses.\033[0m")
                print(f"You requested verse {verse_start}.")
                sys.exit(1)
                
            if verse_end < 1 or verse_end > max_verses:
                print(f"\033[1;31mError: Surah {surah['name']} only has {max_verses} verses.\033[0m")
                print(f"You requested verse {verse_end}.")
                sys.exit(1)
                
            if verse_start > verse_end:
                print("\033[1;31mError: Start verse must be less than or equal to end verse.\033[0m")
                print(f"You requested {verse_start}-{verse_end}.")
                sys.exit(1)
                
        # Display the verses
        display_verses(surah, verse_start, verse_end, show_tafsir)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\033[1;30mGoodbye!\033[0m")
