def normalize_name(name):
    """Normalize a name to standard search key format (lowercase, alpha-only, no prefixes)."""
    name = name.lower()
    # Remove leading 'the '
    if name.startswith("the "):
        name = name[4:]
    # Remove common Arabic prefixes
    name = re.sub(r'^(al|an|ash|ar|at|ad|az|el|as|al-|an-|ash-|ar-|at-|ad-|az-|el-|as-)', '', name)
    # Remove all non-alphanumeric characters
    name = re.sub(r'[^a-z0-9]', '', name)
    return name

def find_surah(query):
    """
    Find a surah based on the query string.
    Can match:
      - Numeric ID (1-114)
      - Transliterated name (exact or substring)
      - English translation (exact or substring)
      - Alias keys (exact or substring)
      - Fuzzy matches as fallback
    Returns:
      - A dictionary (if exact/unique match)
      - A list of dictionaries (if multiple matches/suggestions)
      - None (if no match)
    """
    # 1. Try numeric ID
    if query.isdigit():
        num = int(query)
        if 1 <= num <= 114:
            return next(s for s in SURAHS if s["id"] == num)
        return None

    query_norm = normalize_name(query)
    if not query_norm:
        return None

    # 2. Try exact normalized match
    for s in SURAHS:
        if normalize_name(s["name"]) == query_norm or normalize_name(s["english"]) == query_norm:
            return s
        for alias in s["aliases"]:
            if normalize_name(alias) == query_norm:
                return s

    # 3. Try substring match (case-insensitive)
    substring_matches = []
    for s in SURAHS:
        if (query_norm in normalize_name(s["name"]) or 
            query_norm in normalize_name(s["english"]) or
            any(query_norm in normalize_name(alias) for alias in s["aliases"])):
            substring_matches.append(s)
            
    if len(substring_matches) == 1:
        return substring_matches[0]
    elif len(substring_matches) > 1:
        return substring_matches

    # 4. Fuzzy fallback match
    # Map normalized names back to surah dicts
    name_map = {}
    for s in SURAHS:
        name_map[normalize_name(s["name"])] = s
        name_map[normalize_name(s["english"])] = s
        for alias in s["aliases"]:
            name_map[normalize_name(alias)] = s

    all_names = list(name_map.keys())
    close_matches = difflib.get_close_matches(query_norm, all_names, n=3, cutoff=0.5)

    if close_matches:
        suggested_surahs = []
        seen_ids = set()
        for match in close_matches:
            surah = name_map[match]
            if surah["id"] not in seen_ids:
                suggested_surahs.append(surah)
                seen_ids.add(surah["id"])
        return suggested_surahs

    return None

def parse_query(args_string):
    """
    Parse a query string like "2:255", "2:255-256", "fatihah 2", "cow:255-256"
    Returns:
      (chapter_query_str, verse_start, verse_end)
      verse_start and verse_end can be None if not specified.
    """
    args_string = args_string.strip()
    
    # Matches: chapter separator verse [range]
    # e.g., "2:255", "2:255-256", "al-baqarah 255", "al-baqarah: 255-256"
    pattern = r'^(.+?)(?:\s*:\s*|\s+)(\d+)(?:\s*-\s*(\d+))?$'
    match = re.match(pattern, args_string)
    if match:
        chapter_part = match.group(1).strip()
        verse_start = int(match.group(2))
        verse_end = int(match.group(3)) if match.group(3) else verse_start
        return chapter_part, verse_start, verse_end

    # Simple chapter-only query
    return args_string, None, None

